[
  {
    "version": "v0.9",
    "createSurface": {
      "surfaceId": "eda-findings",
      "catalogId": "https://a2ui.org/specification/v0_9/basic_catalog.json"
    }
  },
  {
    "version": "v0.9",
    "updateComponents": {
      "surfaceId": "eda-findings",
      "components": [
        { "id": "root",          "component": "Column",  "alignment": "start",        "children": { "explicitList": ["title", "findings_list"] } },
        { "id": "title",         "component": "Text",    "text": "EDA Findings",       "variant": "h3" },
        { "id": "findings_list", "component": "List",    "dataBinding": "/findings",   "componentId": "finding_row" },
        { "id": "finding_row",   "component": "Row",     "alignment": "spaceBetween",  "children": { "explicitList": ["col_name", "col_flag"] } },
        { "id": "col_name",      "component": "Text",    "text": { "path": "/column" } },
        { "id": "col_flag",      "component": "Text",    "text": { "path": "/flag" } }
      ]
    }
  },
  {
    "version": "v0.9",
    "updateDataModel": {
      "surfaceId": "eda-findings",
      "path": "/",
      "value": {
        "findings": [
          { "column": "price",   "flag": "right_skewed", "note": "log candidate" },
          { "column": "income",  "flag": "right_skewed", "note": "log candidate" },
          { "column": "balance", "flag": "right_skewed", "note": "" }
        ]
      }
    }
  },
  {
    "version": "v0.9",
    "createSurface": {
      "surfaceId": "eda-action",
      "catalogId": "https://a2ui.org/specification/v0_9/basic_catalog.json"
    }
  },
  {
    "version": "v0.9",
    "updateComponents": {
      "surfaceId": "eda-action",
      "components": [
        { "id": "root",           "component": "Card",   "child": "card_body" },
        { "id": "card_body",      "component": "Column", "alignment": "start", "children": { "explicitList": ["heading", "rationale", "buttons"] } },
        { "id": "heading",        "component": "Text",   "text": { "path": "/prompt" },    "variant": "h3" },
        { "id": "rationale",      "component": "Text",   "text": { "path": "/rationale" } },
        { "id": "buttons",        "component": "Row",    "alignment": "end", "children": { "explicitList": ["confirm", "dismiss"] } },
        { "id": "confirm_label",  "component": "Text",   "text": "Apply transform" },
        { "id": "confirm",        "component": "Button", "child": "confirm_label", "variant": "primary",  "action": { "event": { "name": "confirm_transform", "context": { "column": "price", "transform": "log" } } } },
        { "id": "dismiss_label",  "component": "Text",   "text": "Not now" },
        { "id": "dismiss",        "component": "Button", "child": "dismiss_label",  "variant": "default", "action": { "event": { "name": "dismiss", "context": { "column": "price" } } } }
      ]
    }
  },
  {
    "version": "v0.9",
    "updateDataModel": {
      "surfaceId": "eda-action",
      "path": "/",
      "value": {
        "prompt":    "Log-transform `price`?",
        "rationale": "`price` is right-skewed — a log transform usually helps downstream models converge."
      }
    }
  },
  {
    "version": "v0.9",
    "createSurface": {
      "surfaceId": "training-verdict",
      "catalogId": "https://a2ui.org/specification/v0_9/basic_catalog.json"
    }
  },
  {
    "version": "v0.9",
    "updateComponents": {
      "surfaceId": "training-verdict",
      "components": [
        { "id": "root",        "component": "Card",   "child": "card_body" },
        { "id": "card_body",   "component": "Column", "alignment": "start", "children": { "explicitList": ["heading", "reason", "buttons"] } },
        { "id": "heading",     "component": "Text",   "text": { "path": "/heading" }, "variant": "h3" },
        { "id": "reason",      "component": "Text",   "text": { "path": "/reason" } },
        { "id": "buttons",     "component": "Row",    "alignment": "end", "children": { "explicitList": ["stop", "keep"] } },

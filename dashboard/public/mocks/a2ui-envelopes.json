        { "id": "keep_label",  "component": "Text",   "text": "Keep going" },
        { "id": "keep",        "component": "Button", "child": "keep_label",  "variant": "default", "action": { "event": { "name": "keep_training",  "context": { "run_id": "demo-overfit-001", "step": 350, "verdict": "overfitting" } } } }
      ]
    }
  },
  {
    "version": "v0.9",
    "updateDataModel": {
      "surfaceId": "training-verdict",
      "path": "/",
      "value": {
        "heading": "Verdict @ step 350: overfitting",
        "reason":  "val_loss bottoms at 0.5391 around epoch 17 and rises to 0.9287 by epoch 30 — overfitting."
      }
